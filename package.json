        "@types/jest": "^30.0.0",
        "@types/node": "25.9.3",
        "@types/react": "19.2.14",
        "eslint-config-prettier": "^10.1.8",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "prettier": "^3.8.4"
